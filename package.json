{
    "name": "ia-contactcenter-saas",
    "private": true,
    "version": "0.1.0",
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "dev": "pnpm --dir apps/web dev",
        "build": "pnpm --dir apps/web build",
        "start": "pnpm --dir apps/web start",
        "lint": "pnpm --dir apps/web lint",
        "typecheck": "pnpm --dir apps/web exec tsc --noEmit",
        "test": "echo \"Tests pending\"",
        "db:migrations": "echo \"Use supabase/migrations\"",
        "seed:demo": "node scripts/seed-demo-data.js",
        "seed:demo:no-reset": "node scripts/seed-demo-data.js --no-reset",
        "validate:seed-demo": "node scripts/validate-demo-seed-data.js",
        "smoke:tenant-members": "node scripts/smoke-tenant-members.js",
        "smoke:tenant-settings": "node scripts/smoke-tenant-settings.js",
        "smoke:billing-readiness": "node scripts/smoke-billing-subscription-scaffolding.js",
        "smoke:lead-intake": "node scripts/smoke-lead-intake-source-mapping.js",
        "smoke:manager-view": "node scripts/smoke-manager-view.js",
        "smoke:commercial-insights": "node scripts/smoke-commercial-insights.js",
        "preflight:release:candidate": "node scripts/preflight-release-candidate.js --pack AB",
        "preflight:release:pack-a": "node scripts/preflight-release-candidate.js --pack A",
        "preflight:release:pack-ab": "node scripts/preflight-release-candidate.js --pack AB",
        "smoke:release-readiness": "node scripts/smoke-release-readiness.js",
        "smoke:release:candidate": "node scripts/run-release-smokes.js --pack AB",
        "smoke:release:pack-a": "node scripts/run-release-smokes.js --pack A",
        "smoke:release:pack-ab": "node scripts/run-release-smokes.js --pack AB",
        "smoke:release:ci": "node scripts/run-release-smokes.js --pack AB --skipPreflight --jsonOut .tmp/release-smokes-ci.json"
    }
}